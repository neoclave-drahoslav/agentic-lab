{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-instruction-lab/config.schema.json",
  "title": "Agent Instruction Lab Config",
  "type": "object",
  "required": [
    "globalSources",
    "roles",
    "domains",
    "adapters",
    "domainAdapterTemplate",
    "copilotPathInstructionTemplate",
    "copilotPathInstructions",
    "cursorDomainRuleTemplate",
    "cursorDomainRules",
    "claudeAgentTemplate",
    "claudeAgentsTargetDir"
  ],
  "properties": {
    "globalSources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "path": { "$ref": "#/$defs/agentSourcePath" }
        },
        "additionalProperties": false
      }
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/domain" }
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapter" }
    },
    "domainAdapterTemplate": { "$ref": "#/$defs/agentSourcePath" },
    "copilotPathInstructionTemplate": { "$ref": "#/$defs/agentSourcePath" },
    "copilotPathInstructions": {
      "type": "array",
      "items": { "$ref": "#/$defs/copilotPathInstruction" }
    },
    "cursorDomainRuleTemplate": { "$ref": "#/$defs/agentSourcePath" },
    "cursorDomainRules": {
      "type": "array",
      "items": { "$ref": "#/$defs/cursorDomainRule" }
    },
    "claudeAgentTemplate": { "$ref": "#/$defs/agentSourcePath" },
    "claudeAgentsTargetDir": { "$ref": "#/$defs/repoTargetPath" }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "agentSourcePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "(^/|^[A-Za-z]:|\\.\\.)" }
    },
    "repoTargetPath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "(^/|^[A-Za-z]:|\\.\\.)" }
    },
    "sourceRef": {
      "type": "object",
      "required": ["id", "title", "path"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "$ref": "#/$defs/agentSourcePath" }
      },
      "additionalProperties": false
    },
    "domain": {
      "type": "object",
      "required": [
        "id",
        "name",
        "sourceDir",
        "ownerTeam",
        "ownerPaths",
        "runtimePaths",
        "reviewers",
        "riskLevel",
        "files",
        "testCommands",
        "localAdapterTarget"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "sourceDir": { "$ref": "#/$defs/agentSourcePath" },
        "ownerTeam": { "$ref": "#/$defs/nonEmptyString" },
        "ownerPaths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "runtimePaths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "reviewers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "riskLevel": { "enum": ["low", "medium", "high", "critical"] },
        "files": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/sourceRef" } },
        "testCommands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "localAdapterTarget": { "$ref": "#/$defs/repoTargetPath" }
      },
      "additionalProperties": false
    },
    "adapter": {
      "type": "object",
      "required": ["id", "target", "template", "title", "notes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "target": { "$ref": "#/$defs/repoTargetPath" },
        "template": { "$ref": "#/$defs/agentSourcePath" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "notes": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "copilotPathInstruction": {
      "type": "object",
      "required": ["id", "domainId", "target", "applyTo"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "domainId": { "$ref": "#/$defs/id" },
        "target": { "$ref": "#/$defs/repoTargetPath" },
        "applyTo": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "cursorDomainRule": {
      "type": "object",
      "required": ["id", "domainId", "target"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "domainId": { "$ref": "#/$defs/id" },
        "target": { "$ref": "#/$defs/repoTargetPath" }
      },
      "additionalProperties": false
    }
  }
}